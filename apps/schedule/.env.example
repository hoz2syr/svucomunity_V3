# ─────────────────────────────────────────────────────────────────
# Supabase Configuration
# ─────────────────────────────────────────────────────────────────
# عنوان URL لمشروع Supabase
# Supabase project URL
VITE_SUPABASE_URL=https://your-project.supabase.co

# مفتاح العميل العام (anon key) للوصول من المتصفح
# Public anonymous key for client-side access
VITE_SUPABASE_ANON_KEY=your-anon-key

# ─────────────────────────────────────────────────────────────────
# Google Gemini AI (via Supabase Edge Function)
# ─────────────────────────────────────────────────────────────────
# ⚠️ ملاحظة: مفتاح API يجب تخزينه كـ Supabase Edge Function secret
# ⚠️ Note: The API key should be stored in Supabase Edge Function secrets, not here
# اسم نموذج Gemini المستخدم لاستخراج الجدول من الصور
# Gemini model name used for schedule extraction from images
VITE_GEMINI_MODEL=gemini-1.5-flash
