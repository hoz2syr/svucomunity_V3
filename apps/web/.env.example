# ════════════════════════════════════════════════════════════════════════════════
# SVU Community — متغيرات البيئة (Environment Variables)
# ════════════════════════════════════════════════════════════════════════════════
# انسخ هذا الملف إلى `.env` واملأ القيم المناسبة لمشروعك.
# ════════════════════════════════════════════════════════════════════════════════

# ── Supabase Configuration ─────────────────────────────────────────────────────
# عنوان URL لمشروع Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
# مفتاح Anonymous (Public) لعميل Supabase
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── Debug Mode ────────────────────────────────────────────────────────────────
# تفعيل وضع التصحيح (Debug) — يظهر معلومات إضافية في وحدة التحكم
# القيم الممكنة: true | false
VITE_SVU_DEBUG=false
