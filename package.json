{
  "name": "svu-community",
  "version": "1.0.0",
  "private": true,
  "description": "SVU Community - University Student Platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@svu-community/web",
    "dev:courses": "turbo run dev --filter=@svu-community/courses",
    "dev:schedule": "turbo run dev --filter=@svu-community/schedule",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@svu-community/web",
    "build:courses": "turbo run build --filter=@svu-community/courses",
    "build:schedule": "turbo run build --filter=@svu-community/schedule",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "packageManager": "npm@9.0.0"
}
