{
  "name": "svu-community",
  "version": "1.0.0",
  "private": true,
  "description": "SVU Community - University Student Platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "lucide-react": "^0.546.0",
    "sonner": "^2.0.7"
  },
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@svu-community/web",
    "dev:courses": "turbo run dev --filter=@svu-community/courses",
    "dev:schedule": "turbo run dev --filter=@svu-community/schedule",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@svu-community/web",
    "build:courses": "turbo run build --filter=@svu-community/courses",
    "build:schedule": "turbo run build --filter=@svu-community/schedule",
    "lint": "eslint . --ext .js,.ts,.tsx --report-unused-disable-directives --max-warnings 0",
    "typecheck": "npx tsc -b --force",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "@esbuild/win32-x64": "^0.28.1",
    "@rollup/rollup-win32-x64-msvc": "^4.61.1",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.0.0",
    "globals": "^15.0.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.61.0",
    "vite": "^6.3.5",
    "vite-tsconfig-paths": "^6.1.1",
    "@vitejs/plugin-react": "^4.7.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "packageManager": "npm@10.8.2"
}
