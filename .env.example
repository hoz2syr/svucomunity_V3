# ============================================================
# SVU Community - Environment Variables
# انسخ هذا الملف إلى .env.local واملأ القيم من مشروع Supabase
# ============================================================

# عنوان مشروع Supabase
# المصدر: Supabase Dashboard → Project Settings → API → Project URL
VITE_SUPABASE_URL=

# مفتاح anon/public
# المصدر: Supabase Dashboard → Project Settings → API → anon public
# ملاحظة: هذا المفتاح ممكّن للاستخدام من العميل ولا يكشف بيانات حساسة
VITE_SUPABASE_ANON_KEY=

# معرّف عميل Google OAuth
# المصدر: Google Cloud Console → APIs & Services → Credentials
# يجب تفعيل Google provider في Supabase: Authentication → Providers → Google
VITE_GOOGLE_CLIENT_ID=

# ============================================================
# Edge Function Secrets
# لا تضع مفاتيح Service Role في .env.local أو في كود المتصفح.
# اضبطها عبر Supabase CLI:
# supabase secrets set SUPABASE_URL="https://YOUR_PROJECT_ID.supabase.co"
# supabase secrets set SUPABASE_SERVICE_ROLE_KEY="YOUR_SERVICE_ROLE_KEY"
# supabase secrets set ALLOWED_ORIGINS="https://your-domain.com"
# ============================================================
