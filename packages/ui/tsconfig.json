{
  "extends": "@svu-community/config/tsconfig/react",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@radix-ui/*": ["../../node_modules/@radix-ui/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.d.ts"],
  "references": [
    { "path": "../../packages/supabase-client" },
    { "path": "../../packages/types" }
  ],
  "exclude": ["node_modules", "dist"]
}
