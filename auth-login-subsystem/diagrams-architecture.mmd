graph TB
    subgraph ["Frontend Layer"]
        direction TB
        A1["apps/web<br/>(Vanilla SPA + HTML/JS)"]
        A2["apps/admin<br/>(React + shadcn/ui)"]
    end

    subgraph "Shared Libraries"
        direction LR
        S1["packages/ui<br/>useAuth hook"]
        S2["packages/supabase-client<br/>client / server / middleware"]
        S3["packages/types<br/>User / AuthState"]
    end

    subgraph Supabase
        direction LR
        B1["Supabase Auth<br/>(GoTrue / JWT)"]
        B2["PostgreSQL RLS"]
        B3["Edge Functions<br/>admin-actions"]
    end

    A1 -->|"uses"| S2
    A1 -->|"uses"| S1
    A2 -->|"uses"| S1
    A2 -->|"uses"| S2
    S2 -->|"depends on"| S3
    S2 -->|"auth calls (browser)"| B1
    S2 -->|"admin calls (service_role)"| B3
    B3 -->|"reads/writes via RLS"| B2
    B1 -->|"auth.users linked to public.users"| B2

    style A1 fill:#1f2937,color:#fff
    style A2 fill:#1f2937,color:#fff
    style S1 fill:#111827,color:#fff
    style S2 fill:#111827,color:#fff
    style B1 fill:#064e3b,color:#fff
    style B3 fill:#064e3b,color:#fff
    style B2 fill:#064e3b,color:#fff
