sequenceDiagram
    actor User
    participant UI as apps/web login page (HTML + page-login.js)
    participant Core as core.js / config.js
    participant SB as Supabase Auth (browser client)
    participant DB as PostgreSQL (public.users via RLS)

    User->>UI: Open login page
    UI->>Core: checkExistingSession()
    Core->>SB: auth.getSession() + auth.getUser()
    alt Active session
        SB-->>Core: session + user
        Core-->>UI: redirectToDashboard()
        UI-->>User: navigate to dashboard
    else No valid session
        SB-->>Core: null
        Core-->>UI: clearUserSession() + rendering form
        UI-->>User: Show login form
        User->>UI: submit email + password
        UI->>Core: validate (regex + min length)
        alt Validation fails
            Core-->>UI: showToast(error)
            UI-->>User: inline error
        else Validation passes
            UI->>SB: auth.signInWithPassword()
            SB-->>UI: session + user (or error)
            alt Auth failed
                UI->>Core: map error to safe message
                Core-->>UI: generic error text
                UI-->>User: showToast(generic error)
            else Auth success
                UI->>Core: loadCurrentUser(db)
                Core->>DB: SELECT ... FROM users WHERE id = auth.uid()
                DB-->>Core: profile row + is_active / is_admin
                alt Inactive user
                    Core-->>UI: null
                    UI-->>User: treated as invalid session
                else Active user
                    Core-->>UI: cachedUser + success toast
                    UI-->>User: redirect to dashboard
                end
            end
        end
    end
